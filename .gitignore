### Windows
# Windows thumbnail cache files
Thumbs.db
# Generated Python artifacts
__pycache__/
*.py[cod]
*$py.class

# Local editor and OS noise
.DS_Store
*.swp
*.swo

# Local audit outputs
*.tmp
*.log

# Folder config file
[Dd]esktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows shortcuts
*.lnk

### VS Code
# VSCode settings (keep shared configuration)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Local History for Visual Studio Code
.history/

